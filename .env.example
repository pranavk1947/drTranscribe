# drTranscribe Environment Variables
# Copy this file to .env and fill in your API keys
# Only the providers you plan to use need to be configured

# OpenAI API Key (for transcription: "openai" / extraction: "openai")
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (for transcription: "groq" - default, FREE tier available)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (for transcription: "gemini" / extraction: "gemini" - default)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (for extraction: "claude")
CLAUDE_API_KEY=your_claude_api_key_here

# Azure OpenAI Configuration (for transcription: "azure" / extraction: "azure")
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
